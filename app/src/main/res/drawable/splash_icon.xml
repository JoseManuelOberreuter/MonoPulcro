<?xml version="1.0" encoding="utf-8"?>
<!-- Ícono del system splash: fondo azul con ondas celestes y el mono centrado -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo azul con ondas sutiles -->
    <item android:drawable="@drawable/splash_bg_waves" />

    <!-- Mono con padding mayor para que se vea completo -->
    <item
        android:top="26dp"
        android:bottom="26dp"
        android:left="26dp"
        android:right="26dp"
        android:drawable="@drawable/mono_pulcro" />

</layer-list>
