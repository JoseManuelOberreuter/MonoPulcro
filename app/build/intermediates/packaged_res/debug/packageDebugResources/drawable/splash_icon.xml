<?xml version="1.0" encoding="utf-8"?>
<!-- Ícono del system splash: círculo celeste con el mono adentro con padding -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Círculo de fondo celeste pálido -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#BAE6FD" />
        </shape>
    </item>

    <!-- Mono con padding interno para que no llegue al borde del círculo -->
    <item
        android:bottom="18dp"
        android:drawable="@drawable/mono_pulcro"
        android:left="18dp"
        android:right="18dp"
        android:top="18dp" />

</layer-list>
